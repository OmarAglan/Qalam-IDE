{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "windows-mingw",
            "displayName": "Windows MinGW (Qt from QALAM_QT_DIR)",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/windows-debug",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "$env{QALAM_QT_DIR}",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-release",
            "inherits": "windows-mingw",
            "displayName": "Windows Release (Qt from QALAM_QT_DIR)",
            "binaryDir": "${sourceDir}/build/windows-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-mingw-qt6102",
            "displayName": "Windows MinGW (C:/Qt/6.10.2/mingw_64)",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/windows-debug",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "C:/Qt/6.10.2/mingw_64",
                "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe",
                "CMAKE_MAKE_PROGRAM": "C:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-release-qt6102",
            "inherits": "windows-mingw-qt6102",
            "displayName": "Windows Release (C:/Qt/6.10.2/mingw_64)",
            "binaryDir": "${sourceDir}/build/windows-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/linux-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "$env{QALAM_QT_DIR}"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macOS Release",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/macos-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "$env{QALAM_QT_DIR}"
            }
        }
    ],
    "buildPresets": [
        { "name": "debug", "configurePreset": "windows-mingw" },
        { "name": "release", "configurePreset": "windows-release" },
        { "name": "debug-qt6102", "configurePreset": "windows-mingw-qt6102" },
        { "name": "release-qt6102", "configurePreset": "windows-release-qt6102" },
        { "name": "linux-release", "configurePreset": "linux-release" },
        { "name": "macos-release", "configurePreset": "macos-release" }
    ]
}
